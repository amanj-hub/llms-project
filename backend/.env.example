# ══════════════════════════════════════════
#  LearnSphere Backend — Environment Variables
# ══════════════════════════════════════════

# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster.mongodb.net/llms_v3?retryWrites=true&w=majority

# JWT Secret (change this in production!)
JWT_SECRET=your_jwt_secret_here

# CORS — Frontend URL (set to your deployed frontend URL)
CLIENT_URL=http://localhost:5500

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
